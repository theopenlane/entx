	seen := make(map[string]struct{})
	var values []string

	add := func(s string) {
		if s == "" {
			return
		}

		if _, ok := seen[s]; ok {
			return
		}

		seen[s] = struct{}{}
		values = append(values, s)
	}

	if km.SourceField != "" {
		if v, ok := raw[km.SourceField]; ok {
			var s string
			if json.Unmarshal(v, &s) == nil {
				add(s)
			}
		}
	}

	if km.SourceList != "" {
		if v, ok := raw[km.SourceList]; ok {
			var list []string
			if json.Unmarshal(v, &list) == nil {
				for _, s := range list {
					add(s)
				}
			}
		}
	}

	return values
}
